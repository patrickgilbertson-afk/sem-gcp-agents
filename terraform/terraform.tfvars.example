# ============================================================================
# SEM GCP Agents - Terraform Variables
# ============================================================================
# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================

# GCP Project Configuration
project_id = "your-project-id"  # TODO: Replace with your GCP project ID
region     = "us-central1"       # GCP region for resources

# Google Ads Configuration
google_ads_customer_id = "1234567890"  # TODO: Replace with your Google Ads customer ID (no dashes)

# Slack Configuration
slack_approval_channel_id = "C01234567"  # TODO: Replace with your Slack channel ID
                                          # Get from Slack: Right-click channel → View channel details → Copy channel ID

# ============================================================================
# SAFETY SETTINGS
# ============================================================================

# Dry Run Mode (RECOMMENDED: Start with true)
dry_run_mode = true  # true = Generate recommendations but don't apply changes
                     # false = Apply changes to Google Ads (PRODUCTION MODE)

# ============================================================================
# OPTIONAL VARIABLES (with defaults)
# ============================================================================

# Google Ads MCC Account (optional)
# google_ads_login_customer_id = "9876543210"  # Uncomment if using MCC account

# Kill Switch (emergency stop)
# kill_switch_enabled = false  # Set to true to force all agents into dry run

# Environment
# environment = "development"  # development, staging, production

# Logging
# log_level = "INFO"  # DEBUG, INFO, WARNING, ERROR

# BigQuery Datasets
# dataset_agents = "sem_agents"      # Dataset for agent tables
# dataset_raw    = "sem_ads_raw"     # Dataset for Google Ads data

# Cloud Run Service
# service_name = "sem-gcp-agents"           # Cloud Run service name
# cloud_run_image = "gcr.io/PROJECT_ID/sem-gcp-agents:latest"  # Docker image

# ============================================================================
# MINIMAL EXAMPLE (Quick Start)
# ============================================================================
# Just set these 4 required variables to get started:
#
# project_id                = "my-gcp-project"
# region                    = "us-central1"
# google_ads_customer_id    = "1234567890"
# slack_approval_channel_id = "C01234567"
# dry_run_mode              = true
#
# ============================================================================
