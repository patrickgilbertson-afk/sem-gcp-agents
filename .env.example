# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=sa-sem-agents@your-project-id.iam.gserviceaccount.com

# BigQuery
BQ_DATASET_RAW=sem_ads_raw
BQ_DATASET_AGENTS=sem_agents

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Portkey (LLM Gateway) - REQUIRED for production
# All LLM calls route through Portkey for observability, caching, and cost tracking
# Get your keys from: https://app.portkey.ai
PORTKEY_API_KEY=pk-your-portkey-api-key
PORTKEY_VIRTUAL_KEY_ANTHROPIC=anthropic-your-virtual-key
PORTKEY_VIRTUAL_KEY_GOOGLE=google-your-virtual-key
PORTKEY_ENABLE_CACHE=true
PORTKEY_CACHE_TTL=3600

# Direct API Keys (OPTIONAL - local development fallback only)
# In production, configure these in Portkey dashboard virtual keys
# Leave blank if using Portkey (recommended)
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APPROVAL_CHANNEL_ID=C01234567

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
DRY_RUN=true
KILL_SWITCH_ENABLED=false

# Safety Limits
MAX_OPERATIONS_PER_RUN=10000
MAX_DAILY_SPEND_INCREASE_PCT=15
RATE_LIMIT_REQUESTS_PER_SECOND=1

# Approval Settings
APPROVAL_TIMEOUT_HOURS=8
APPROVAL_ESCALATION_HOURS=4
