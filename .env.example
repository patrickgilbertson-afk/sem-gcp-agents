# =============================================================================
# SEM GCP Agents - Environment Configuration (Example)
# =============================================================================
# This file contains NON-SECRET configuration only.
# All secrets are loaded from GCP Secret Manager at runtime.
#
# Setup Instructions:
#   1. Copy this file to .env: cp .env.example .env
#   2. Update the values below with your actual configuration
#   3. Ensure secrets exist in GCP Secret Manager (see GCP_SECRETS_CHECKLIST.md)
#   4. Authenticate: gcloud auth application-default login
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=sem-agents@your-project-id.iam.gserviceaccount.com

# -----------------------------------------------------------------------------
# BigQuery Datasets
# -----------------------------------------------------------------------------
BQ_DATASET_RAW=sem_ads_raw
BQ_DATASET_AGENTS=sem_agents

# -----------------------------------------------------------------------------
# Google Analytics 4 Integration (Optional)
# -----------------------------------------------------------------------------
# Leave blank if not using GA4 integration
GA4_DATASET=
GA4_PROPERTY_ID=

# -----------------------------------------------------------------------------
# Google Ads API - Account IDs (Non-Secret)
# -----------------------------------------------------------------------------
# Find at: https://ads.google.com → top-right corner (remove dashes)
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# -----------------------------------------------------------------------------
# Portkey Configuration (Non-Secret Settings)
# -----------------------------------------------------------------------------
PORTKEY_ENABLE_CACHE=true
PORTKEY_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Slack Configuration (Non-Secret)
# -----------------------------------------------------------------------------
# Find: Right-click #sem-agent-approvals → View details → Channel ID
SLACK_APPROVAL_CHANNEL_ID=C01234567

# Comma-separated list of Slack user IDs authorized to approve/reject recommendations
# Find user ID: Click profile → More → Copy member ID
# Leave empty to allow all users in the channel
SLACK_APPROVAL_USER_WHITELIST=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DRY_RUN=true
KILL_SWITCH_ENABLED=false

# -----------------------------------------------------------------------------
# Safety Limits
# -----------------------------------------------------------------------------
MAX_OPERATIONS_PER_RUN=10000
MAX_DAILY_SPEND_INCREASE_PCT=15
RATE_LIMIT_REQUESTS_PER_SECOND=1

# -----------------------------------------------------------------------------
# Approval Settings
# -----------------------------------------------------------------------------
APPROVAL_TIMEOUT_HOURS=8
APPROVAL_ESCALATION_HOURS=4

# =============================================================================
# SECRETS - DO NOT ADD HERE
# =============================================================================
# All secrets must be stored in GCP Secret Manager.
# The application loads them automatically at runtime.
#
# Required secrets in GCP Secret Manager:
#
# Option A (Recommended - 7 secrets):
#   - google-ads-credentials (JSON format)
#   - slack-bot-token
#   - slack-signing-secret
#   - portkey-api-key
#   - portkey-virtual-key-anthropic
#   - portkey-virtual-key-google
#   - anthropic-api-key (optional - for local dev fallback)
#
# Option B (Individual Google Ads secrets - 10 secrets):
#   - google-ads-developer-token
#   - google-ads-client-id
#   - google-ads-client-secret
#   - google-ads-refresh-token
#   - slack-bot-token
#   - slack-signing-secret
#   - portkey-api-key
#   - portkey-virtual-key-anthropic
#   - portkey-virtual-key-google
#   - anthropic-api-key (optional)
#
# Setup:
#   1. Create secrets: bash scripts/setup_secrets_individual.sh
#   2. Verify: gcloud secrets list --project=your-project-id
#   3. Test: python -c "from src.config import settings; print(settings.gcp_project_id)"
#
# See: GCP_SECRETS_CHECKLIST.md for detailed setup instructions
# =============================================================================
